# Required
REOON_API_KEY=your_reoon_api_key_here

# Email delivery (Gmail/Workspace example — use any SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@digitalnetworkingagency.com
SMTP_PASS=your_16_char_app_password
DELIVERY_EMAIL=sam@digitalnetworkingagency.com

# Optional — protects /run, /download, /leads/recent endpoints
API_TOKEN=

# Perpetual loop — keeps running forever
PERPETUAL_ENABLED=true
BATCH_SIZE=500
BETWEEN_BATCH_SECONDS=30
EXHAUSTED_RETRY_SECONDS=3600

# Public URL for download links (Railway provides RAILWAY_PUBLIC_DOMAIN env var; set this manually if needed)
PUBLIC_BASE_URL=
